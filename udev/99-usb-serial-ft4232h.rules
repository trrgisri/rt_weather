# ============================================
# FTDI FT4232H Quad USB-UART (0403:6011)
#   Device SN: FT98LNZA/FT9CRRJC
# ============================================

# Port A
SUBSYSTEM=="tty", \
  ENV{ID_VENDOR_ID}=="0403", ENV{ID_MODEL_ID}=="6011", ENV{ID_SERIAL_SHORT}=="FT98LNZA", \
  ENV{ID_USB_INTERFACE_NUM}=="00", \
  GROUP="users", MODE="0666", \
  SYMLINK+="ttyFT4232_A"

# Port B
SUBSYSTEM=="tty", \
  ENV{ID_VENDOR_ID}=="0403", ENV{ID_MODEL_ID}=="6011", ENV{ID_SERIAL_SHORT}=="FT98LNZA", \
  ENV{ID_USB_INTERFACE_NUM}=="01", \
  GROUP="users", MODE="0666", \
  SYMLINK+="ttyFT4232_B"

# Port C
SUBSYSTEM=="tty", \
  ENV{ID_VENDOR_ID}=="0403", ENV{ID_MODEL_ID}=="6011", ENV{ID_SERIAL_SHORT}=="FT98LNZA", \
  ENV{ID_USB_INTERFACE_NUM}=="02", \
  GROUP="users", MODE="0666", \
  SYMLINK+="ttyFT4232_C"

# Port D
SUBSYSTEM=="tty", \
  ENV{ID_VENDOR_ID}=="0403", ENV{ID_MODEL_ID}=="6011", ENV{ID_SERIAL_SHORT}=="FT98LNZA", \
  ENV{ID_USB_INTERFACE_NUM}=="03", \
  GROUP="users", MODE="0666", \
  SYMLINK+="ttyFT4232_D"